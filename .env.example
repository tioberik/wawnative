# Firebase web konfiguracija (Project settings -> Your apps -> Web app -> SDK setup and configuration)
# Kopiraj ovaj fajl u .env i popuni stvarnim vrijednostima iz Firebase konzole.
# Prefiks EXPO_PUBLIC_ je obavezan da bi Expo ubacio varijable u klijentski bundle.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
