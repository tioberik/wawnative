rules_version = '2';

// Sigurnosna pravila za Firestore.
//
// Uloge:
//  - Običan korisnik: vidi/uređuje SAMO svoje narudžbe (polje ownerId).
//  - Admin: vidi, uređuje i briše SVE narudžbe. Admin se određuje postojanjem
//    dokumenta /admins/{uid} (postavlja se ručno u Firebase konzoli).
//  - Kupci su DIJELJENI: svi prijavljeni ih vide i uređuju; briše vlasnik ili admin.
//
// VAŽNO: za listanje (query) servisni sloj mora filtrirati po ownerId kad
// korisnik NIJE admin (where("ownerId", "==", uid)), inače Firestore odbija upit.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Admin = postoji dokument /admins/{uid} za prijavljenog korisnika.
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Vlasnik postojećeg dokumenta
    function isOwner() {
      return isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // Novi dokument pripada prijavljenom korisniku
    function isCreatingOwn() {
      return isSignedIn()
        && request.resource.data.ownerId == request.auth.uid;
    }

    // Admin oznake — korisnik smije pročitati samo svoju (za određivanje uloge).
    // Upisuje se isključivo ručno u konzoli, ne iz aplikacije.
    match /admins/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if false;
    }

    // Kupci su zajednički: svi prijavljeni vide i uređuju, briše vlasnik ili admin.
    // ownerId se ne smije mijenjati pri uređivanju.
    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow create: if isCreatingOwn();
      allow update: if isSignedIn()
        && request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isOwner() || isAdmin();
    }

    // Narudžbe: vlasnik vidi/uređuje svoje; admin ima puni pristup svima.
    match /orders/{orderId} {
      allow read: if isOwner() || isAdmin();
      allow create: if isCreatingOwn();
      allow update, delete: if isOwner() || isAdmin();
    }
  }
}
